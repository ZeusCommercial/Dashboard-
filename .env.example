# GoHighLevel — Private Integration token (v2 API)
GHL_PRIVATE_TOKEN=
GHL_LOCATION_ID=

# Custom field IDs (Settings -> Custom Fields -> click field -> ID in URL)
GHL_FIELD_REFERRED_BY=
GHL_FIELD_AM_ID=
GHL_FIELD_SAM_ID=
GHL_FIELD_CAMPAIGN=
GHL_FIELD_NET_BROKER_FEE=

# Which pipeline holds deals, and stage names counted as funded
GHL_FUNDED_PIPELINE_ID=
GHL_FUNDED_STAGE_NAMES=funded,closed won,won

# Campaign values that mark Tier 2 (substring, case-insensitive)
GHL_TIER_2_MARKERS=tier 2,tier2,professional,paid

# Iframe access
DASHBOARD_TOKEN_SECRET=
DASHBOARD_REQUIRE_TOKEN=false
DASHBOARD_BASE_URL=https://YOUR-RENDER-URL.onrender.com
ALLOWED_FRAME_ANCESTORS=https://app.gohighlevel.com https://*.gohighlevel.com https://*.leadconnectorhq.com https://*.msgsndr.com

# Stale deal threshold (days)
STALE_DEAL_DAYS=21
